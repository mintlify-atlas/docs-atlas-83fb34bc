  "keyFeatures": [
    "One-command deployment of LLMs on domestic Chinese AI chips",
    "Support for Huawei Ascend 910B, 310P and other domestic hardware",
    "Multiple inference engine backends (vLLM, MindIE, MLGuider, Omni-Infer)",
    "Automatic hardware detection and engine selection",
    "Pre-configured models including Qwen, GLM-4, MiniMax, DeepSeek",
    "OpenAI-compatible API endpoints",
    "Zero-configuration setup with intelligent defaults",
    "Multi-device tensor parallelism support",
    "Docker-based runtime isolation",
    "Configuration versioning and updates"
  ],
  "publicApiSurface": [
    "xw serve - Start the xw HTTP server",
    "xw pull <model> - Download a model from registry",
    "xw run <model> - Run a model interactively",
    "xw start <model> - Start a model as a service",
    "xw ls - List available models",
    "xw ps - List running model instances",
    "xw stop <instance> - Stop a running instance",
    "xw logs <instance> - View instance logs",
    "xw device - Show detected hardware devices",
    "xw config - Manage configuration",
    "xw update - Update model and device configurations",
    "xw reload - Reload configuration without restart",
    "xw version - Show version information",
    "GET /health - Health check endpoint",
    "GET /api/v1/models - List models",
    "GET /api/v1/models/:id - Get model details",
    "POST /api/v1/runtime/start - Start model instance",
    "GET /api/v1/runtime/instances - List instances",
    "DELETE /api/v1/runtime/instances/:id - Stop instance",
    "GET /api/v1/devices - List hardware devices",
    "GET /api/v1/config - Get configuration",
    "POST /v1/completions - OpenAI-compatible completions",
    "POST /v1/chat/completions - OpenAI-compatible chat"
  ]
}
